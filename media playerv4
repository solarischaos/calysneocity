<script>
    // Track active fullscreen container
    let activeFullscreenContainer = null;
    const exitBtn = document.getElementById('exitFullscreenBtn');
    
    // Function to exit fullscreen mode
    function exitFullscreenMode() {
        if (activeFullscreenContainer) {
            var videoId = activeFullscreenContainer.id.split('-').pop();
            var btn = document.querySelector('.fullscreen-btn[data-video-id="' + videoId + '"]');
            
            // Remove fullscreen class
            activeFullscreenContainer.classList.remove('video-fullscreen-overlay');
            
            // Reset button text
            if (btn) btn.textContent = '[FS] Fullscreen';
            
            // Hide floating exit button
            exitBtn.classList.remove('visible');
            
            // Clear active container
            activeFullscreenContainer = null;
        }
    }
    
    // Custom fullscreen functionality
    document.querySelectorAll('.fullscreen-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var videoId = this.getAttribute('data-video-id');
            var container = document.getElementById('video-container-' + videoId);
            
            // If this container is already fullscreen, exit it
            if (activeFullscreenContainer === container) {
                exitFullscreenMode();
                return;
            }
            
            // If another video is fullscreen, exit it first
            if (activeFullscreenContainer) {
                exitFullscreenMode();
            }
            
            // Make container fullscreen - CSS handles the iframe sizing automatically
            container.classList.add('video-fullscreen-overlay');
            
            // Change button text
            this.textContent = '[X] Exit';
            
            // Set as active container
            activeFullscreenContainer = container;
            
            // Show floating exit button
            exitBtn.classList.add('visible');
        });
    });
    
    // Floating exit button click handler
    exitBtn.addEventListener('click', function() {
        exitFullscreenMode();
    });
    
    // Press Escape to exit fullscreen
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && activeFullscreenContainer) {
            exitFullscreenMode();
        }
    });
</script>

