<!-- Media player i'm working on, it already has videos in it, that can be swapped out. theres 3 themes here : dark,light, and amber. 
Amber is a fun one, its mostly browns and golds and yellows) . this ones v4, so its had a few iterations already. --> 
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>TV Viewer — 4:3 Channel Player</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            /* noise gif  */
            background: url('https://64.media.tumblr.com/0ac9d68d6f8915794e1fbd8ca8b6a245/35d2387a6c099773-0f/s400x600/9c3f9f32a995de10a1a45a860a5b67ec6af46b8e.gif') center/cover no-repeat fixed;
            background-size: cover;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', system-ui, 'Segoe UI', 'SF Mono', 'Fira Code', monospace;
            padding: 24px;
            position: relative;
        }

        /* semi-transparent overlay for readability */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.55);
            pointer-events: none;
            z-index: 0;
        }

        /* MAIN TV CARD — glassmorphism, 4:3 aspect ratio container */
        .tv-card {
            max-width: 900px;
            width: 100%;
            aspect-ratio: 3 / 4;
            background: rgba(18, 24, 30, 0.88);
            backdrop-filter: blur(18px);
            border-radius: 48px;
            padding: 28px 28px 32px;
            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(122, 233, 255, 0.4);
            transition: all 0.2s ease;
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
        }

        /* player area — 4:3 inner frame (classic TV shape) */
        .player-area {
            flex: 1;
            background: #000000;
            border-radius: 28px;
            overflow: hidden;
            border: 2px dashed rgba(122, 233, 255, 0.65);
            box-shadow: inset 0 0 15px rgba(0, 0, 0, 0.6), 0 4px 12px rgba(0, 0, 0, 0.3);
            transition: all 0.2s;
            position: relative;
        }

        #dynamicPlayer {
            width: 100%;
            height: 100%;
            border: none;
            display: block;
            background: #0a0c10;
        }

        /* channel strip — 6 buttons, plain text, retro feel */
        .channel-strip {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 12px;
            margin: 20px 0 16px;
        }

        /* tv button — plain text, no clock, minimal but with neon undertones */
        .tv-btn {
            background: rgba(10, 16, 22, 0.8);
            border: 1px solid rgba(122, 233, 255, 0.4);
            border-radius: 60px;
            padding: 8px 20px;
            font-size: 0.85rem;
            font-weight: 600;
            font-family: 'SF Mono', 'Fira Code', monospace;
            letter-spacing: 0.8px;
            text-transform: lowercase;
            color: #cae9ff;
            cursor: pointer;
            transition: all 0.18s ease;
            backdrop-filter: blur(4px);
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.3);
        }

        .tv-btn:hover {
            transform: scale(1.02);
            background: rgba(122, 233, 255, 0.25);
            border-color: #7ae9ff;
            color: white;
            box-shadow: 0 0 10px #7ae9ff80;
        }

        .tv-btn.active {
            background: #7ae9ff;
            border-color: #ffffff;
            color: #0a1f2c;
            box-shadow: 0 0 12px #7ae9ff;
            text-shadow: 0 0 2px rgba(0,0,0,0.2);
        }

        /* info line — subtle retro details */
        .info-line {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: baseline;
            gap: 12px;
            margin-top: 8px;
            padding-top: 12px;
            border-top: 1px solid rgba(122, 233, 255, 0.25);
            font-size: 0.7rem;
            font-family: monospace;
            color: #aaddff;
            letter-spacing: 0.4px;
        }

        .reset-tip {
            background: rgba(0, 0, 0, 0.5);
            padding: 4px 12px;
            border-radius: 50px;
            cursor: pointer;
            transition: 0.12s;
            font-weight: 500;
            border: 1px solid rgba(122,233,255,0.3);
        }

        .reset-tip:hover {
            background: #7ae9ff30;
            color: #e0f4ff;
            transform: scale(0.98);
            border-color: #7ae9ff;
        }

        /* micro-interaction: flash effect */
        .click-flash {
            transition: 0.07s linear;
            filter: brightness(1.2);
            transform: scale(0.96);
        }

        /* Responsive: keep 4:3 ratio, adjust padding */
        @media (max-width: 700px) {
            .tv-card {
                padding: 20px;
                border-radius: 36px;
            }
            .tv-btn {
                padding: 6px 14px;
                font-size: 0.7rem;
            }
            .channel-strip {
                gap: 8px;
            }
            .info-line {
                font-size: 0.6rem;
                flex-direction: column;
                align-items: center;
                text-align: center;
            }
        }

        @media (max-width: 500px) {
            .tv-card {
                padding: 16px;
                border-radius: 28px;
            }
            .tv-btn {
                padding: 5px 12px;
                font-size: 0.65rem;
            }
            .channel-strip {
                gap: 6px;
            }
        }
    </style>
</head>
<body>

<div class="tv-card">
    <!-- main TV screen area: 4:3 frame inside the 4:3 card -->
    <div class="player-area">
        <iframe id="dynamicPlayer" 
                title="tv channel player" 
                src="https://ytch.tv/" 
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                allowfullscreen>
        </iframe>
    </div>

    <!-- 6 channel buttons — plain text, matching your spec -->
    <div class="channel-strip">
        <button class="tv-btn active" data-channel="ytch">television</button>
        <button class="tv-btn" data-channel="music">music</button>
        <button class="tv-btn" data-channel="theatre">theatre</button>
        <button class="tv-btn" data-channel="gaming">gaming</button>
        <button class="tv-btn" data-channel="stories">stories</button>
        <button class="tv-btn" data-channel="twitch">painting</button>
    </div>

    <div class="info-line">
        <span>📺 4:3 · dashed border · old time radio & youtube mixes</span>
        <span id="resetPlayerBtn" class="reset-tip">⟳ reset to television</span>
        <span style="margin-left: auto;">🎛️ ytch.tv + playlists + twitch + OTR</span>
    </div>
</div>

<script>
    (function() {
        // DOM elements
        const playerFrame = document.getElementById('dynamicPlayer');
        const btns = document.querySelectorAll('.tv-btn');
        const resetBtn = document.getElementById('resetPlayerBtn');

        // Channel URLs — exactly as given, stories uses Old Time Radio embed (oldtime.radio)
        const channelMap = {
            ytch:    'https://ytch.tv/',
            music:   'https://www.youtube.com/embed/videoseries?list=PL4MpeqJSMtUVrFT7lHbhwDleO6PzmivPK',
            theatre: 'https://www.youtube.com/embed/videoseries?list=PL4MpeqJSMtUX-lAJFv2O8ur3NoNmgLXPx',
            gaming:  'https://www.youtube.com/embed/videoseries?list=PL4MpeqJSMtUWwPO4Ul3BZC2GoT1Dhp_B8',
            stories: 'https://oldtime.radio',   // Old Time Radio embed / streaming
            twitch:  'https://player.twitch.tv/?channel=ephemeralcalyptra&parent=calyptalinks.neocities.org&autoplay=false'
        };

        // helper: update active button styling
        function setActiveButton(channelId) {
            btns.forEach(btn => {
                const btnChannel = btn.getAttribute('data-channel');
                if (btnChannel === channelId) {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });
        }

        // flash animation on any button / reset
        function addFlash(element) {
            if (!element) return;
            element.classList.add('click-flash');
            setTimeout(() => {
                element.classList.remove('click-flash');
            }, 100);
        }

        // core function: load channel into iframe
        function setChannel(channelId) {
            const url = channelMap[channelId];
            if (url) {
                // simple security: keep same-origin policy but external embed is fine
                playerFrame.src = url;
                setActiveButton(channelId);
                // optional: tiny status vibe (no clock, just feedback)
                console.log(`[tv viewer] switched to ${channelId}`);
            } else {
                console.warn(`unknown channel: ${channelId}`);
            }
        }

        // attach click handlers to each channel button
        btns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                addFlash(btn);
                const channelId = btn.getAttribute('data-channel');
                if (channelId) {
                    setChannel(channelId);
                }
            });
        });

        // reset button: go back to television (ytch.tv) and update active state
        if (resetBtn) {
            resetBtn.addEventListener('click', (e) => {
                e.preventDefault();
                addFlash(resetBtn);
                setChannel('ytch');
                // extra micro UX: show reset feedback
                const originalText = resetBtn.innerText;
                resetBtn.innerText = '✓ television';
                setTimeout(() => {
                    resetBtn.innerText = originalText;
                }, 800);
            });
        }

        // ensure that the default channel is 'ytch' and iframe matches active button on page load
        // (since default iframe src is already ytch.tv, but we sync active class just in case)
        const defaultChannel = 'ytch';
        setActiveButton(defaultChannel);
        
        // optional: if for any reason the iframe src is not matching the active button on reload,
        // we set it explicitly. but initial HTML has src="https://ytch.tv/", so it's consistent.
        // In case of any external navigation? no, we control via channel buttons only.
        // also handle possible iframe errors silently (user friendly)
        playerFrame.addEventListener('error', () => {
            // just a passive fallback; not intrusive
            console.log('iframe load error — maybe blocked by external site');
        });
    })();
</script>
</body>
</html>
